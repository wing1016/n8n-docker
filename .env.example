# PostgreSQL Configuration
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_to_secure_password

# Redis Configuration
REDIS_PASSWORD=change_me_to_secure_password

# N8N Configuration
N8N_HOST=0.0.0.0
N8N_PORT=5678
NODE_ENV=production
TIMEZONE=UTC

# Security
N8N_ENCRYPTION_KEY=change_me_to_random_string_minimum_32_characters_long

# Webhook Configuration
# This should be your domain name where n8n will be accessible
WEBHOOK_URL=https://n8n.example.com

# Optional: SMTP Configuration for Email Notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_SENDER=noreply@example.com

# Optional: Sentry for Error Tracking
# SENTRY_DSN=https://your-sentry-dsn
